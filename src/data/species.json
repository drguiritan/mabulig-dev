[
  {
    "id": "platymantis",
    "scientific": "Platymantis corrugatus",
    "common": "Corrugated Forest Frog",
    "family": "Ceratobatrachidae",
    "order": "Anura",
    "habitat": "Primary and secondary rainforest floor, leaf litter",
    "distribution": "Luzon Island, Philippines",
    "conservation": "Least Concern",
    "badgeColor": "positive",
    "description": "A direct-developing frog found in the leaf litter of Philippine rainforests. It lays eggs on the ground that hatch directly into small frogs, bypassing a free-living tadpole stage.",
    "model": "models/platymantis.glb",
    "available": true,
    "external_features": {
      "dorsal": [
        {
          "label": "Dorsal Skin",
          "description": "Strongly corrugated (ridged) skin surface, giving the species its common name.",
          "point": [
            0,
            0.65,
            0
          ]
        },
        {
          "label": "Snout",
          "description": "Rounded and moderately projecting snout viewed from above.",
          "point": [
            0,
            0.35,
            0.95
          ]
        },
        {
          "label": "Interorbital Space",
          "description": "Region between the eyes; slightly concave and narrower than the upper eyelid.",
          "point": [
            0,
            0.58,
            0.62
          ]
        },
        {
          "label": "Tympanum",
          "description": "Circular external eardrum located just behind the eye; distinct and visible.",
          "point": [
            0.28,
            0.44,
            0.52
          ]
        }
      ],
      "ventral": [
        {
          "label": "Ventral Skin",
          "description": "Granular texture on the belly surface; paler coloration compared to the dorsum.",
          "point": [
            0,
            0.12,
            0.05
          ]
        },
        {
          "label": "Throat",
          "description": "Smooth to slightly granular; single internal vocal sac in males.",
          "point": [
            0,
            0.22,
            0.68
          ]
        },
        {
          "label": "Pectoral Region",
          "description": "Chest area with fine granules; no glandular swellings present.",
          "point": [
            0.12,
            0.16,
            0.42
          ]
        }
      ],
      "limbs": [
        {
          "label": "Forelimbs",
          "description": "Moderately robust; forearms relatively short compared to hindlimbs.",
          "point": [
            0.42,
            0.18,
            0.28
          ]
        },
        {
          "label": "Fingers",
          "description": "Four fingers; unwebbed with slightly expanded discs at the tips for gripping leaf litter.",
          "point": [
            0.62,
            0.02,
            0.72
          ]
        },
        {
          "label": "Hindlimbs",
          "description": "Well-developed for terrestrial locomotion; moderately long relative to body size.",
          "point": [
            0.52,
            0.18,
            -0.48
          ]
        },
        {
          "label": "Toes",
          "description": "Five toes; basal webbing only; toe discs moderately expanded.",
          "point": [
            0.65,
            0.02,
            -0.82
          ]
        },
        {
          "label": "Subarticular Tubercles",
          "description": "Rounded tubercles beneath the finger and toe joints; prominent and single.",
          "point": [
            0.55,
            0.06,
            -0.62
          ]
        }
      ],
      "other": [
        {
          "label": "Eye",
          "description": "Large and prominent; horizontal pupil; golden-bronze iris with dark reticulation.",
          "point": [
            0.22,
            0.54,
            0.68
          ]
        },
        {
          "label": "Nostril",
