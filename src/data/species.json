  {
    "id": "ansoniamuelleri",
    "scientific": "Ansonia muelleri",
    "common": "Mueller's Slender Toad",
    "family": "Bufonidae",
    "order": "Anura",
    "habitat": "Rocky streams in primary lowland and hill dipterocarp forest",
    "distribution": "Borneo — Sarawak, Sabah (Malaysia), Brunei",
    "conservation": "Least Concern",
    "badgeColor": "positive",
    "description": "A small, slender stream toad that clings to wet rocks in fast-flowing forest streams. Named after German herpetologist Ludwig Müller, it is recognised by its warty skin and long slender limbs.",
    "model": "models/ansoniamuelleri.glb",
    "available": true,
    "external_features": {
      "dorsal": [
        {
          "label": "Dorsal Skin",
          "description": "Covered in numerous small warts and spinules; rough texture adapted to rocky stream habitats.",
          "point": [
            0,
            0.6,
            0
          ]
        },
        {
          "label": "Snout",
          "description": "Pointed and projecting; longer than the diameter of the eye when viewed laterally.",
          "point": [
            0,
            0.3,
            0.92
          ]
        },
        {
          "label": "Interorbital Space",
          "description": "Flat to slightly convex; wider than the upper eyelid width.",
          "point": [
            0,
            0.52,
            0.6
          ]
        },
        {
          "label": "Tympanum",
          "description": "Small and partially distinct; may be obscured by surrounding skin texture.",
          "point": [
            0.22,
            0.42,
            0.5
          ]
        }
      ],
      "ventral": [
        {
          "label": "Ventral Skin",
          "description": "Granular to shagreen; yellowish or pale with dark mottling in some individuals.",
          "point": [
            0,
            0.1,
            0.05
          ]
        },
        {
          "label": "Throat",
          "description": "Granular; paired vocal sacs absent — Ansonia toads are generally silent or produce faint calls.",
          "point": [
            0,
            0.2,
            0.62
          ]
        },
        {
          "label": "Pectoral Region",
          "description": "Flat chest with fine granular skin; no distinct glandular structures.",
          "point": [
            0.1,
            0.13,
            0.38
          ]
        }
      ],
      "limbs": [
        {
          "label": "Forelimbs",
          "description": "Long and slender; adapted for clinging to wet rock surfaces in fast-flowing streams.",
          "point": [
            0.38,
            0.14,
            0.22
          ]
        },
        {
          "label": "Fingers",
          "description": "Four fingers; unwebbed; narrow discs; outer fingers longer, aiding rock grip.",
          "point": [
            0.55,
            0.02,
            0.68
          ]
        },
        {
          "label": "Hindlimbs",
          "description": "Notably long and slender relative to body; key identification feature of the genus Ansonia.",
          "point": [
            0.48,
            0.14,
            -0.52
          ]
        },
        {
          "label": "Toes",
          "description": "Five toes; webbing reduced to basal portion; narrow toe discs present.",
          "point": [
            0.6,
            0.02,
            -0.88
          ]
        },
        {
          "label": "Subarticular Tubercles",
          "description": "Small, single tubercles beneath joints; less prominent than in other bufonids.",
          "point": [
            0.5,
            0.04,
            -0.68
          ]
        }
      ],
      "other": [
        {
          "label": "Eye",
          "description": "Medium-sized; horizontal pupil; iris may show coppery or bronze coloration.",
          "point": [
            0.18,
            0.5,
            0.65
          ]
        },
        {
          "label": "Nostril",
          "description": "Small nostrils close to the snout tip; slightly directed upward.",
          "point": [
            0.05,
            0.36,
            0.9
          ]
        },
        {
          "label": "Canthus Rostralis",
          "description": "Distinct angular ridge from nostril to eye; sharply defined.",
          "point": [
            0.12,
            0.44,
            0.78
          ]
        },
        {
          "label": "Parotoid Glands",
          "description": "Elongated parotoid glands present behind each eye; secrete mild toxins as a defense mechanism.",
          "point": [
            0.28,
            0.55,
            0.32
          ]
        }
      ]
    }
