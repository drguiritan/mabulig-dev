  {
    "id": "staurois_natator",
    "scientific": "Staurois natator",
    "common": "White-spotted Torrent Frog",
    "family": "Ranidae",
    "order": "Anura",
    "habitat": "Rocky fast-flowing mountain streams in primary dipterocarp forest",
    "distribution": "Borneo (Sabah, Sarawak, Kalimantan), Philippines (Palawan)",
    "conservation": "Least Concern",
    "badgeColor": "positive",
    "description": "A striking torrent frog renowned for its unique 'foot-flagging' courtship display, where males wave their webbed hindfoot to signal rivals and attract mates amid the noise of rushing water. It clings to slick boulders in fast-flowing highland streams and is identified by bold white spots on a dark dorsum.",
    "model": "models/staurois_natator.glb",
    "available": true,
    "external_features": {
      "dorsal": [
        {
          "label": "Dorsal Coloration",
          "description": "Dark brown to black dorsum adorned with irregular white or cream spots; highly contrasting pattern used in species identification.",
          "point": [0, 0.62, 0]
        },
        {
          "label": "Snout",
          "description": "Truncate to slightly rounded snout; shorter than the eye diameter when viewed laterally.",
          "point": [0, 0.32, 0.9]
        },
        {
          "label": "Interorbital Space",
          "description": "Flat and wide; approximately equal to the width of the upper eyelid.",
          "point": [0, 0.55, 0.58]
        },
        {
          "label": "Tympanum",
          "description": "Distinct and circular; diameter roughly half that of the eye; positioned just posterior to the eye.",
          "point": [0.26, 0.46, 0.5]
        }
      ],
      "ventral": [
        {
          "label": "Ventral Surface",
          "description": "Pale yellowish-white with dark mottling; smooth to finely granular texture.",
          "point": [0, 0.11, 0.04]
        },
        {
          "label": "Throat",
          "description": "White or cream with faint dark flecking; single internal vocal sac present in males.",
          "point": [0, 0.24, 0.65]
        },
        {
          "label": "Pectoral Region",
          "description": "Smooth chest with subtle pale yellow wash; no prominent glandular structures.",
          "point": [0.13, 0.15, 0.4]
        }
      ],
      "limbs": [
        {
          "label": "Forelimbs",
          "description": "Moderately robust; forearm and hand used for gripping wet rock surfaces in torrential streams.",
          "point": [0.4, 0.16, 0.25]
        },
        {
          "label": "Fingers",
          "description": "Four unwebbed fingers with well-developed adhesive discs; enlarged discs critical for gripping smooth wet boulders.",
          "point": [0.6, 0.03, 0.7]
        },
        {
          "label": "Hindlimbs",
          "description": "Long and muscular; positioned for powerful leaping between boulders and performing the iconic foot-flagging display.",
          "point": [0.5, 0.16, -0.5]
        },
        {
          "label": "Webbed Feet",
          "description": "Fully webbed toes — the defining feature used in foot-flagging displays to communicate across noisy torrents.",
          "point": [0.66, 0.03, -0.85]
        },
        {
          "label": "Subarticular Tubercles",
          "description": "Single, rounded tubercles beneath toe joints; well-developed to aid traction on wet rock.",
          "point": [0.54, 0.05, -0.65]
        }
      ],
      "other": [
        {
          "label": "Eye",
          "description": "Large and protuberant; horizontal pupil; bronze to gold iris with fine dark reticulation — aids vision in fast-moving stream environments.",
          "point": [0.2, 0.52, 0.66]
        },
        {
          "label": "Nostril",
          "description": "Small nostrils positioned near the tip of the snout; slightly directed upward and outward.",
          "point": [0.07, 0.37, 0.88]
        },
        {
          "label": "Canthus Rostralis",
          "description": "Moderately distinct ridge from nostril to the anterior corner of the eye.",
          "point": [0.13, 0.45, 0.76]
        },
        {
          "label": "White Dorsal Spots",
          "description": "Scattered cream or white spots on the dorsum; pattern varies individually and is used as a visual signal during male-male competition.",
          "point": [0.3, 0.6, 0.2]
        }
      ]
    }
  },
